/* ===== 浅绿主题 - 清新护眼 ===== */

/* 全局背景色 */
body, #page, .page-context-header {
    background-color: #e8f5e9 !important;
}

/* ===== 课程弹窗 - 浅绿版 ===== */
.collapse.in {
    position: fixed !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    z-index: 999999 !important;
    width: 600px !important;
    max-width: 85vw !important;
    background: #f1f8e9 !important;
    border-radius: 16px !important;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2) !important;
    padding: 0 !important;
    max-height: 80vh !important;
    overflow-y: auto !important;
    animation: slideIn 0.2s ease-out !important;
}

.collapse.in::before {
    content: "📚 我的课程";
    display: block !important;
    padding: 16px 24px !important;
    font-size: 18px !important;
    font-weight: 600 !important;
    background: #c8e6c9 !important;
    color: #2e7d32 !important;
    border-radius: 16px 16px 0 0 !important;
    border-bottom: 1px solid #a5d6a7 !important;
    margin-bottom: 0 !important;
}

.custom-close-btn {
    position: absolute !important;
    top: 12px !important;
    right: 18px !important;
    font-size: 20px !important;
    color: #2e7d32 !important;
    cursor: pointer !important;
    z-index: 1000000 !important;
    font-weight: bold !important;
    background: transparent !important;
    width: 28px !important;
    height: 28px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 50% !important;
}

.custom-close-btn:hover {
    background: rgba(46,125,50,0.1) !important;
    color: #1b5e20 !important;
}

.collapse.in .list-group-item {
    display: block !important;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    border-bottom: 1px solid #d0e8d0 !important;
    background: #ffffff !important;
}

.collapse.in .list-group-item a {
    display: block !important;
    padding: 14px 24px !important;
    color: #333333 !important;
    text-decoration: none !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    transition: all 0.2s ease !important;
    background: #ffffff !important;
}

.collapse.in .list-group-item a:hover {
    background: #e8f5e9 !important;
    color: #2e7d32 !important;
    padding-left: 32px !important;
}

/* 即将到来的事件区块 */
.block_calendar_upcoming {
    background-color: #66bb6a !important;
    border-radius: 8px !important;
    margin-bottom: 16px !important;
}

.block_calendar_upcoming .card-body,
.block_calendar_upcoming .card-title,
.block_calendar_upcoming .card-text {
    background-color: #66bb6a !important;
    color: #ffffff !important;
}

.block_calendar_upcoming a {
    color: #fff9c4 !important;
}

/* 最近访问的课程区块 */
.block_recentlyaccessedcourses {
    background-color: #66bb6a !important;
    border-radius: 8px !important;
    margin-bottom: 16px !important;
}

.block_recentlyaccessedcourses .card-body,
.block_recentlyaccessedcourses .card-title,
.block_recentlyaccessedcourses .card-text {
    background-color: #66bb6a !important;
    color: #ffffff !important;
}

.block_recentlyaccessedcourses .dashboard-card {
    background-color: #81c784 !important;
}

.block_recentlyaccessedcourses .course-info-container {
    background-color: #81c784 !important;
}

.block_recentlyaccessedcourses .text-truncate,
.block_recentlyaccessedcourses .coursename,
.block_recentlyaccessedcourses .text-muted {
    color: #ffffff !important;
}

/* 课程卡片样式 */
.dashboard-card {
    background-color: #81c784 !important;
}

.dashboard-card .card-body,
.dashboard-card .course-info-container {
    background-color: #81c784 !important;
}

.dashboard-card .text-truncate,
.dashboard-card .coursename,
.dashboard-card .text-muted {
    color: #ffffff !important;
}

/* 个人主页顶部样式 */
.page-context-header {
    background-color: #66bb6a !important;
    border-radius: 8px !important;
    padding: 16px !important;
    margin-bottom: 20px !important;
}

.page-header-headings h1 {
    color: #ffffff !important;
}

.header-button-group .btn {
    background-color: #81c784 !important;
    color: #ffffff !important;
}

#page-header .card {
    background-color: #4caf50 !important;
}

/* 侧边栏 */
#nav-drawer {
    background-color: #2e7d32 !important;
}

/* 课程磁贴 */
#multi_section_tiles {
    background-color: #66bb6a !important;
    padding: 16px !important;
    border-radius: 12px !important;
}

.tile {
    background-color: #81c784 !important;
    border-radius: 12px !important;
}

.tile h3 {
    color: #ffffff !important;
}

/* 顶部导航栏 */
.fixed-top.navbar {
    background-color: #4caf50 !important;
}

.navbar .nav-link,
.navbar .dropdown-toggle,
.navbar .navbar-brand {
    color: #ffffff !important;
}

/* 下拉菜单 */
.dropdown-menu {
    background-color: #81c784 !important;
}

.dropdown-menu .dropdown-item {
    color: #ffffff !important;
}

/* 卡片区域 */
.card-deck {
    background-color: #66bb6a !important;
    padding: 16px !important;
    border-radius: 12px !important;
}

.card {
    background-color: #81c784 !important;
}

.card-body {
    background-color: #81c784 !important;
}

.card-title a {
    color: #ffffff !important;
}

.btn-primary {
    background-color: #388e3c !important;
    border-color: #2e7d32 !important;
}

@keyframes slideIn {
    from {
        opacity: 0 !important;
        transform: translate(-50%, -45%) !important;
    }
    to {
        opacity: 1 !important;
        transform: translate(-50%, -50%) !important;
    }
}
